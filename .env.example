
# ── Dev Container (ephemeral Code Server sessions) ───────────────────────────
# Base image — built by CI from services/devcontainer/Dockerfile
DEVCONTAINER_IMAGE=ghcr.io/pikatsuto/kasm-devcontainer:latest

# Resources per session (only one active at a time)
DEVCONTAINER_MEMORY=4g
DEVCONTAINER_CPUS=2.0

# Wildcard domain for ephemeral URLs (e.g. dev.example.com → *.dev.example.com)
# Wildcard DNS required: *.DEV_DOMAIN → server IP
DEV_DOMAIN=

# Idle timeout before automatic shutdown (ms, default 30min)
DEV_IDLE_MS=1800000

# Docker network shared with Traefik (same as coolify)
DEV_NETWORK=coolify
