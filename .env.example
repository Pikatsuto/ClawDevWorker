
# ── Dev Container (sessions Code Server éphémères) ────────────────────────────
# Image de base — buildée par le CI depuis services/devcontainer/Dockerfile
DEVCONTAINER_IMAGE=ghcr.io/pikatsuto/kasm-devcontainer:latest

# Ressources par session (une seule active à la fois)
DEVCONTAINER_MEMORY=4g
DEVCONTAINER_CPUS=2.0

# Domaine wildcard pour les URLs éphémères (ex: dev.example.com → *.dev.example.com)
# Wildcard DNS requis : *.DEV_DOMAIN → IP serveur
DEV_DOMAIN=

# Timeout inactivité avant fermeture automatique (ms, défaut 30min)
DEV_IDLE_MS=1800000

# Réseau Docker partagé avec Traefik (même que coolify)
DEV_NETWORK=coolify
