# ── Required ──────────────────────────────────────────────────────────────────
CHAT_DOMAIN=chat.example.com
OPENCLAW_GATEWAY_PASSWORD=changeme

# ── Forgejo ───────────────────────────────────────────────────────────────────
GIT_DOMAIN=git.example.com
FORGEJO_DB_PASSWORD=change-this-password
FORGEJO_SECRET_KEY=change-this-secret-key
FORGEJO_INTERNAL_TOKEN=change-this-internal-token
FORGEJO_RUNNER_TOKEN=generate-from-forgejo-admin
# FORGEJO_SSH_PORT=2222
# FORGEJO_RUNNER_NAME=cdw-runner
# FORGEJO_RUNNER_LABELS=debian-latest:docker://debian:trixie-slim,node-24:docker://node:24-bookworm,docker:docker://docker:27

# Forgejo agent account token (scope: repo)
GIT_PROVIDER_1_TOKEN=your-forgejo-token
FORGEJO_TOKEN=your-forgejo-token

# ── Git providers ─────────────────────────────────────────────────────────────
GIT_PROVIDER_1=forgejo
GIT_PROVIDER_1_URL=http://host-gateway:3000
# GIT_PROVIDER_1_WEBHOOK_SECRET=

# GitHub App (optional)
# GIT_PROVIDER_2=github
# GIT_PROVIDER_2_APP_ID=
# GIT_PROVIDER_2_PRIVATE_KEY_B64=
# GIT_PROVIDER_2_INSTALLATION_ID=
# GIT_PROVIDER_2_WEBHOOK_SECRET=
# GITHUB_TOKEN=

AGENT_GIT_LOGIN=agent

# ── Models ────────────────────────────────────────────────────────────────────
# MODEL_COMPLEX=qwen3.5:27b-q3_k_m
# MODEL_STANDARD=qwen3.5:9b
# MODEL_LIGHT=qwen3.5:4b
# MODEL_TRIVIAL=qwen3.5:2b
# MODEL_CPU=qwen3.5:0.8b
# MODEL_WRITING=mistral:7b

# Per-role override (optional)
# MODEL_SECURITY=qwen3.5:27b-q3_k_m
# MODEL_ARCHITECT=qwen3.5:27b-q3_k_m

# ── VRAM (adjust if using different models) ───────────────────────────────────
# VRAM_COMPLEX=14
# VRAM_STANDARD=5
# VRAM_LIGHT=3
# VRAM_TRIVIAL=2

# ── Dev Container (ephemeral Code Server sessions) ───────────────────────────
DEVCONTAINER_IMAGE=ghcr.io/pikatsuto/cdw-devcontainer:latest
DEVCONTAINER_MEMORY=4g
DEVCONTAINER_CPUS=2.0

# Wildcard domain for ephemeral URLs (*.DEV_DOMAIN → server IP)
DEV_DOMAIN=dev.example.com
DEV_IDLE_MS=1800000
DEV_NETWORK=coolify

# ── Pipeline ──────────────────────────────────────────────────────────────────
# GATE_MAX_RETRIES=3
# GATE_RETRY_UPGRADE=true
# LOOP_DETECT_THRESHOLD=2

# ── GPU scheduler ────────────────────────────────────────────────────────────
# KEEPALIVE_MAX=2
# HUMAN_IDLE_MS=1800000
# UPGRADE_THRESHOLD=30
# DOWNGRADE_STREAK_MAX=3

# ── Ports (Forgejo/Coolify on host) ──────────────────────────────────────────
# FORGEJO_HOST_PORT=3000
# COOLIFY_HOST_PORT=8000
# COOLIFY_PREVIEW_DOMAIN=

# ── Ephemeral containers (code execution sandbox) ────────────────────────────
# EPHEMERAL_MEMORY=1g
# EPHEMERAL_CPUS=1.0
# EPHEMERAL_TIMEOUT=300
