{
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.rulers": [100],
  "editor.minimap.enabled": false,
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.fontSize": 13,
  "git.autofetch": true,
  "git.confirmSync": false,
  "python.defaultInterpreterPath": "/usr/bin/python3",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },
  "docker.host": "unix:///run/user/1000/docker.sock",
  "openclaw.autoConnect": true,
  "openclaw.host": "localhost",
  "openclaw.port": 18790,
  "openclaw.security.readOnly": false,
  "openclaw.security.writeConfirmation": false,
  "openclaw.security.deleteConfirmation": false,
  "openclaw.security.confirmAllActions": false,
  "openclaw.terminal.enabled": true,
  "openclaw.terminal.confirmBeforeRun": false,
  "openclaw.terminal.allowlist": [
    "git *",
    "npm *",
    "yarn *",
    "pnpm *",
    "python3 *",
    "pytest *",
    "docker *",
    "tea *"
  ],
  "telemetry.telemetryLevel": "off",
  "extensions.autoUpdate": false,
  "workbench.startupEditor": "none"
}
