{
  "name": "clawforge-orchestrator",
  "version": "1.0.0",
  "description": "Multi-agent dev/qa pipeline orchestration pour Forgejo avec GPU scheduling",
  "main": "orchestrator/index.js",
  "tools": [
    "task_pickup",
    "task_complete",
    "queue_status",
    "session_health"
  ],
  "config": {
    "forgejoUrl":     { "env": "FORGEJO_URL",     "required": true },
    "forgejoToken":   { "env": "FORGEJO_TOKEN",   "required": true },
    "schedulerUrl":   { "env": "SCHEDULER_URL",   "default": "http://localhost:7070" },
    "workerImage":    { "env": "WORKER_IMAGE",     "default": "ghcr.io/pikatsuto/cdw-worker:latest" }
  }
}
