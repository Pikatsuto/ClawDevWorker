{
  "name": "ClawDevWorker",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "mounts": [
    "source=/home/linuxbrew/.linuxbrew/Caskroom/claude-code,target=/opt/claude-code,type=bind,readonly",
    "source=/home/linuxbrew/.linuxbrew/bin/claude,target=/usr/local/bin/claude,type=bind,readonly",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind",
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "remoteUser": "node",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "postCreateCommand": "npm install"
}
